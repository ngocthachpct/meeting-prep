# Gemini API key (from Google AI Studio) or use Vertex AI ADC instead
GOOGLE_API_KEY=

# Model used by all three sub-agents
AGENT_MODEL=gemini-3.1-flash-lite

# MCP services exposed via gws-mcp-server (stdio transport, spawned by ADK)
GWS_MCP_SERVICES=gmail,calendar,drive

# Optional: Gmail address for follow-up drafts when the transcript has no emails.
# If unset, agent-service resolves it via `gws gmail users getProfile`.
DEFAULT_DRAFT_TO=
